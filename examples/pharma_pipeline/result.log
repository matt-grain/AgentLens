│    def compute_features(mol):                                                                                   │
│        morgan = AllChem.GetMorganFingerprintAsBitVect(mol, radius=3, nBits=2048)                                │
│        maccs = MACCSkeys.GenMACCSKeys(mol)                                                                      │
│        descriptors = [Descriptors.MolLogP(mol), Descriptors.TPSA(mol),                                          │
│                       Descriptors.MolWt(mol), Descriptors.NumHDonors(mol),                                      │
│                       Descriptors.NumHAcceptors(mol), Descriptors.NumRotatableBonds(mol)]                       │
│        return np.concatenate([np.array(morgan), np.array(maccs), descriptors])                                  │
