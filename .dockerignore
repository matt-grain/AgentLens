# Only src/, pyproject.toml, and uv.lock need to land in the agentlens image.
# Everything else is excluded for size, security, and build speed.

# Python virtualenvs + caches
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Git / VCS
.git/
.gitignore
.gitattributes
.github/

# Runtime / test artefacts
traces/
benchmarks/
demo/
examples/
tests/
docs/

# IDE / editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docs + internal working files
# (README.md is NOT excluded — hatchling references it in pyproject.toml for
# the package long description and fails the wheel build without it.)
TODOS.md
CHECKS.md
ARCHITECTURE.md
CLAUDE.md

# Claude / agent memory / local settings
.claude/

# Environment files
.env
.env.local
.env.example

# Docker helpers themselves
Dockerfile
.dockerignore
