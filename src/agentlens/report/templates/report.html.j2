<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgentLens Report — {{ trace.agent_name }}</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-deep:        #101114;
    --bg-surface:     #16181c;
    --bg-elevated:    #1e2025;
    --bg-hover:       #282a30;
    --border:         #363840;
    --text-primary:   #f0f1f3;
    --text-secondary: #c2c4c9;
    --text-tertiary:  #9a9da5;
    --text-muted:     #7d808a;
    --accent:         #E86F33;
    --accent-dim:     rgba(232, 111, 51, 0.22);
    --accent-glow:    rgba(232, 111, 51, 0.55);
    --success:        #3ecf8e;
    --success-dim:    rgba(62, 207, 142, 0.18);
    --warning:        #f0b429;
    --warning-dim:    rgba(240, 180, 41, 0.18);
    --danger:         #ef4444;
    --danger-dim:     rgba(239, 68, 68, 0.18);
    --blue:           #60a5fa;
    --blue-dim:       rgba(96, 165, 250, 0.18);
    --mono:  'IBM Plex Mono', 'SF Mono', 'Monaco', monospace;
    --serif: 'Playfair Display', Georgia, serif;
    --sans:  system-ui, -apple-system, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--sans);
    background: var(--bg-deep);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .container { max-width: 960px; margin: 0 auto; padding: 2.5rem 1.25rem; }

  h1 {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
  }

  h1 .brand { color: var(--accent); }

  h2 {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
  }

  .meta {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.5rem;
    border-left: 2px solid var(--accent-dim);
    padding-left: 0.75rem;
  }

  .meta strong { color: var(--text-tertiary); }

  /* Overall score */
  .overall {
    background: var(--bg-elevated);
    border-radius: 0.75rem;
    padding: 1.75rem 2rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    border: 1px solid var(--border);
  }

  .overall-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .overall-score {
    font-family: var(--mono);
    font-size: 3.25rem;
    font-weight: 600;
    line-height: 1;
    text-shadow: 0 0 24px var(--accent-glow);
  }

  .overall-score.pass { color: var(--success); text-shadow: 0 0 24px rgba(62, 207, 142, 0.45); }
  .overall-score.warn { color: var(--warning); text-shadow: 0 0 24px rgba(240, 180, 41, 0.45); }
  .overall-score.fail { color: var(--danger);  text-shadow: 0 0 24px rgba(239, 68, 68, 0.45); }

  .overall-status {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    border-left: 1px solid var(--border);
    padding-left: 2rem;
  }

  /* Level score cards */
  .section { margin-bottom: 2.5rem; }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 0;
  }

  .card {
    background: var(--bg-elevated);
    border-radius: 0.625rem;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid;
    border-top: 1px solid var(--border);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 0.15s ease;
  }

  .card:hover { background: var(--bg-hover); }
  .card.pass { border-left-color: var(--success); }
  .card.warn { border-left-color: var(--warning); }
  .card.fail { border-left-color: var(--danger); }

  .card-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .card-score {
    font-family: var(--mono);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1;
  }

  .card.pass .card-score { color: var(--success); }
  .card.warn .card-score { color: var(--warning); }
  .card.fail .card-score { color: var(--danger); }

  /* Trajectory timeline */
  details {
    background: var(--bg-surface);
    border-radius: 0.625rem;
    overflow: hidden;
    margin-bottom: 0.5rem;
    border: 1px solid var(--border);
    transition: border-color 0.15s ease;
  }

  details[open] { border-color: var(--accent-dim); }

  summary {
    padding: 0.875rem 1.125rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    list-style: none;
    transition: background 0.15s ease;
  }

  summary::-webkit-details-marker { display: none; }
  summary:hover { background: var(--bg-elevated); }

  summary strong {
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  .badge {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 4px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .badge-llm  { background: var(--blue-dim);    color: var(--blue);    border: 1px solid rgba(96, 165, 250, 0.3); }
  .badge-tool { background: var(--accent-dim);  color: var(--accent);  border: 1px solid rgba(232, 111, 51, 0.3); }
  .badge-other { background: var(--bg-elevated); color: var(--text-muted); border: 1px solid var(--border); }

  .span-icon { font-size: 0.9rem; flex-shrink: 0; }
  .span-icon.ok   { color: var(--success); }
  .span-icon.warn { color: var(--warning); }
  .span-icon.fail { color: var(--danger); }

  .agent-name {
    color: var(--text-tertiary);
    font-size: 0.75rem;
    font-family: var(--mono);
    margin-right: 0.5rem;
  }

  .span-duration {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .span-detail {
    padding: 0.875rem 1.125rem 1.125rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  .span-detail p strong { color: var(--text-secondary); font-size: 0.75rem; }

  .span-detail pre {
    font-family: var(--mono);
    background: var(--bg-deep);
    border: 1px solid var(--border);
    padding: 0.75rem;
    border-radius: 0.375rem;
    overflow-x: auto;
    font-size: 0.72rem;
    color: var(--text-secondary);
    margin-top: 0.375rem;
    line-height: 1.5;
  }

  .token-info {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.625rem;
  }

  /* Evaluator results */
  .result-row {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.875rem 1.125rem;
    margin-bottom: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    transition: border-color 0.15s ease;
  }

  .result-row:hover { border-color: var(--accent-dim); }

  .result-name {
    font-family: var(--mono);
    font-weight: 500;
    font-size: 0.82rem;
    color: var(--text-primary);
  }

  .result-level {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .result-score {
    margin-left: auto;
    font-family: var(--mono);
    font-weight: 600;
    font-size: 0.88rem;
  }

  .result-score.pass { color: var(--success); }
  .result-score.warn { color: var(--warning); }
  .result-score.fail { color: var(--danger); }

  .result-msg {
    width: 100%;
    font-size: 0.78rem;
    color: var(--text-tertiary);
  }

  .evidence {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: 0.375rem;
    list-style: none;
    width: 100%;
  }

  .evidence li { padding: 0.1rem 0; }
  .evidence li::before { content: "— "; color: var(--accent-dim); }

  /* Footer */
  footer {
    margin-top: 4rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    text-align: center;
    letter-spacing: 0.03em;
  }

  footer .brand-footer { color: var(--accent); }
</style>
</head>
<body>
<div class="container">

  <h1><span class="brand">AgentLens</span> Evaluation Report</h1>
  <p class="meta">
    <span><strong>Task:</strong> {{ summary.task }}</span>
    <span><strong>Agent:</strong> {{ trace.agent_name }}</span>
    <span><strong>Trace:</strong> {{ trace.id }}</span>
    <span><strong>Duration:</strong> {{ trace.duration_ms }}ms</span>
    <span><strong>Steps:</strong> {{ trace.spans | length }}</span>
  </p>

  {# Overall score #}
  {% set ov_class = score_class(summary.overall_score) %}
  <div class="overall">
    <div>
      <div class="overall-label">Overall Score</div>
      <div class="overall-score {{ ov_class }}">{{ score_pct(summary.overall_score) }}</div>
    </div>
    <div class="overall-status">
      {% if summary.passed %}All evaluators passed.{% else %}{{ summary.critical_failures | length }} critical failure(s).{% endif %}
    </div>
  </div>

  {# Level score cards #}
  <div class="section">
    <h2>Level Scores</h2>
    <div class="cards">
      {% for level in level_order %}
        {% if level in summary.level_scores %}
          {% set score = summary.level_scores[level] %}
          {% set cls = score_class(score) %}
          <div class="card {{ cls }}">
            <div class="card-label">{{ level.value }}</div>
            <div class="card-score">{{ score_pct(score) }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {# Trajectory timeline #}
  <div class="section">
    <h2>Trajectory Timeline</h2>
    {% for span in trace.spans %}
      {% set is_llm = span.span_type.value == "llm_call" %}
      {% set status_cls = "ok" if span.status.value == "success" else ("fail" if span.status.value == "failure" else "warn") %}
      {% set icon = "✓" if span.status.value == "success" else ("✗" if span.status.value == "failure" else "⚠") %}
      <details>
        <summary>
          <span class="span-icon {{ status_cls }}">{{ icon }}</span>
          {% if is_llm %}
            <span class="badge badge-llm">LLM</span>
          {% else %}
            <span class="badge badge-tool">TOOL</span>
          {% endif %}
          {% if span.metadata.get('agent_name') %}<span class="agent-name">{{ span.metadata['agent_name'] }}</span>{% endif %}<strong>{{ span.name }}</strong>
          <span class="span-duration">{{ span.duration_ms }}ms</span>
        </summary>
        <div class="span-detail">
          <p><strong>Input:</strong></p>
          <pre>{{ span.input | tojson(indent=2) }}</pre>
          {% if span.output %}
            <p style="margin-top:0.625rem"><strong>Output:</strong></p>
            <pre>{{ span.output | tojson(indent=2) }}</pre>
          {% endif %}
          {% if span.token_usage %}
            <p class="token-info">Tokens: {{ span.token_usage.input_tokens }} in / {{ span.token_usage.output_tokens }} out</p>
          {% endif %}
        </div>
      </details>
    {% endfor %}
  </div>

  {# Detailed evaluator results #}
  <div class="section">
    <h2>Evaluator Results</h2>
    {% for result in summary.results %}
      {% set cls = score_class(result.score) %}
      <div class="result-row">
        <span class="result-name">{{ result.evaluator_name }}</span>
        <span class="result-level">{{ result.level.value }}</span>
        <span class="result-score {{ cls }}">{{ score_pct(result.score) }}</span>
        <span class="result-msg">{{ result.message }}</span>
        {% if result.evidence %}
          <ul class="evidence">
            {% for ev in result.evidence %}
              <li>{{ ev }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <footer>
    Generated by <span class="brand-footer">AgentLens</span> &mdash; {{ summary.timestamp.strftime("%Y-%m-%d %H:%M:%S UTC") }}
  </footer>
</div>
</body>
</html>
